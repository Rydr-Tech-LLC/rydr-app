# --- Firebase client config (safe to expose to the browser) ---
# Firebase Console -> Project settings -> General -> Your apps -> Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server-only, never expose, never commit) ---
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines (one line in .env)
FIREBASE_ADMIN_PRIVATE_KEY=

# Session cookie signing — any long random string, e.g. `openssl rand -base64 48`
SESSION_COOKIE_NAME=rydr_mc_session

# --- Transactional email (server-only, never expose) ---
RESEND_API_KEY=
WAITLIST_FROM_EMAIL="Rydr Beta <beta@rydr-go.com>"
WAITLIST_INTERNAL_NOTIFY_EMAIL="support@rydr-go.com"
TESTFLIGHT_RIDER_URL=
TESTFLIGHT_DRIVER_URL=
DISCORD_RIDER_INVITE_URL=
DISCORD_DRIVER_INVITE_URL=

# --- Campus Growth AI (server-only, never expose) ---
OPENAI_API_KEY=
# Optional override; defaults in code if omitted.
OPENAI_MODEL=
OPENAI_CAMPUS_MODEL=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
CAMPUS_OUTREACH_FROM_EMAIL="support@rydr-go.com"
CAMPUS_OUTREACH_BCC_EMAIL="khris.nunnally@rydr-go.com"
