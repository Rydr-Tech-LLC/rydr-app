PORT=3000
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_ADMIN_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=
# Required for the image moderation route to read uploaded photos out of Storage.
# New Firebase projects often use the firebasestorage.app bucket domain.
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Google Cloud Vision (image moderation / SafeSearch)
# Paste the full contents of the service-account JSON key file as a single-line value.
GOOGLE_VISION_CREDENTIALS_JSON=

# Ticketmaster Discovery API
TICKETMASTER_API_KEY=
